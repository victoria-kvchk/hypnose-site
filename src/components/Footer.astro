---
import { t, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="bg-sand-2">
  <hr class="hairline" />
  <div class="wrap flex flex-col items-center gap-1 py-10 text-center md:flex-row md:justify-between md:text-left">
    <p class="display text-[1.15rem] text-ink">
      {t(lang, 'site.title')}<span class="text-terracotta">·</span>
    </p>
    <p class="text-[0.78rem] text-ink-faint">
      &copy; {year} {t(lang, 'site.title')}. {t(lang, 'footer.rights')}
    </p>
  </div>
</footer>
