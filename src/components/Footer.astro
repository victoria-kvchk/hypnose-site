---
import { getLocalizedRoute, type Lang } from '../i18n/utils';
import Newsletter from './Newsletter.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const year = new Date().getFullYear();

/** Contenu du footer, par langue. Les `route` renvoient vers les pages existantes. */
const content = {
  fr: {
    columns: [
      { title: 'Recherche', links: [{ label: 'Axes de recherche', anchor: 'research' }, { label: 'Articles', route: 'articles' }] },
      { title: 'Ressources', links: [{ label: 'Bibliothèque', route: 'bibliography' }, { label: 'Glossaire', route: 'glossary' }, { label: 'FAQ', route: 'faq' }] },
    ],
    newsletter: { title: 'Recevoir la newsletter', placeholder: 'Votre email', action: 'S’inscrire' },
    legal: [{ label: 'Mentions légales', route: 'legal' }, { label: 'Confidentialité', route: 'privacy' }, { label: 'Contact', route: 'contact' }],
    legalAria: 'Liens légaux',
    disclaimer: 'Les contenus de ce site sont informatifs et ne remplacent pas un avis médical. L’hypnose est un complément, jamais un substitut à un traitement. Pour tout usage thérapeutique, consultez un professionnel de santé qualifié.',
  },
  en: {
    columns: [
      { title: 'Research', links: [{ label: 'Research axes', anchor: 'research' }, { label: 'Articles', route: 'articles' }] },
      { title: 'Resources', links: [{ label: 'Library', route: 'bibliography' }, { label: 'Glossary', route: 'glossary' }, { label: 'FAQ', route: 'faq' }] },
    ],
    newsletter: { title: 'Subscribe to the newsletter', placeholder: 'Your email', action: 'Subscribe' },
    legal: [{ label: 'Legal notice', route: 'legal' }, { label: 'Privacy', route: 'privacy' }, { label: 'Contact', route: 'contact' }],
    legalAria: 'Legal links',
    disclaimer: 'The content on this site is informational and does not replace medical advice. Hypnosis is a complement, never a substitute for treatment. For any therapeutic use, consult a qualified healthcare professional.',
  },
}[lang];
---

<footer class="bg-sand">
  <div class="wrap pb-10">
    <hr class="hairline mb-14" />

    {/* bloc principal : logo · 3 colonnes de liens · newsletter */}
    <div class="grid grid-cols-1 gap-x-8 gap-y-12 md:grid-cols-[1fr_1fr_1.8fr] md:gap-10">
      {/* colonnes de liens */}
      {content.columns.map((col) => (
        <nav aria-label={col.title}>
          <p class="eyebrow mb-4 text-ink-soft">{col.title}</p>
          <ul class="space-y-2.5">
            {col.links.map((link) => (
              <li><a href={link.route ? getLocalizedRoute(lang, link.route) : link.anchor ? `/${lang}/#${link.anchor}` : '#'} class="text-[0.875rem] text-ink-soft transition-colors hover:text-terracotta">{link.label}</a></li>
            ))}
          </ul>
        </nav>
      ))}

      {/* newsletter (droite) — pleine largeur sur mobile */}
      <div>
        <p class="eyebrow mb-4 text-ink-soft">{content.newsletter.title}</p>
        <Newsletter lang={lang} variant="footer" />
      </div>
    </div>

    {/* avertissement médical — vaut pour tout le site (articles inclus) */}
    <p class="mt-14 border-t border-line pt-6 max-w-3xl text-[0.78rem] leading-relaxed text-ink-faint">{content.disclaimer}</p>

    {/* barre inférieure */}
    <div class="mt-6 flex flex-col gap-3 border-t border-line pt-6 text-[0.78rem] text-ink-faint md:flex-row md:items-center md:justify-between">
      <p>&copy; {year} Hypnosis Research</p>
      <nav class="flex flex-wrap gap-x-6 gap-y-2" aria-label={content.legalAria}>
        {content.legal.map((link) => (
          <a href={link.route ? getLocalizedRoute(lang, link.route) : '#'} class="transition-colors hover:text-terracotta">{link.label}</a>
        ))}
      </nav>
    </div>
  </div>
</footer>
