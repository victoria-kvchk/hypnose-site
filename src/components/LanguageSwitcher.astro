---
import { getSwitchLangPath, type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const targetLang = lang === 'fr' ? 'en' : 'fr';
const targetPath = getSwitchLangPath(currentPath, targetLang);
---

<a
  href={targetPath}
  class="text-sm font-medium text-gray-500 hover:text-primary-700 uppercase transition-colors"
  aria-label={lang === 'fr' ? 'Switch to English' : 'Passer en français'}
>
  {targetLang.toUpperCase()}
</a>
