---
/**
 * Newsletter — formulaire d'inscription Brevo, réutilisable.
 *
 * Variantes :
 *  - `footer`  : compact, champ souligné + flèche (fond clair).
 *  - `section` : champ arrondi + bouton libellé.
 *
 * Soumission NATIVE (POST classique, url-encodé) vers l'URL du formulaire
 * Brevo : c'est exactement ce que Brevo attend. Le navigateur est redirigé
 * vers la page de confirmation Brevo (configurable côté Brevo pour revenir
 * sur le site). Pas de JS requis.
 */
import { BREVO, newsletterCopy } from '../i18n/newsletter';
import { type Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
  variant?: 'footer' | 'section';
}

const { lang, variant = 'footer' } = Astro.props;
const copy = newsletterCopy[lang];

// id unique du champ (évite les collisions footer/section sur la même page)
const emailId = `nl-email-${variant}`;
const action = BREVO.formAction || undefined;
---

{variant === 'footer' ? (
  <form action={action} method="POST" class="max-w-xs">
    <div class="flex items-center border-b border-line focus-within:border-ink/40">
      <label for={emailId} class="sr-only">{copy.placeholder}</label>
      <input
        id={emailId}
        name={BREVO.emailField}
        type="email"
        required
        autocomplete="email"
        placeholder={copy.placeholder}
        class="w-full bg-transparent py-2 text-[0.875rem] text-ink placeholder:text-ink-faint focus:outline-none"
      />
      {/* piège anti-bot Brevo : invisible, doit rester vide */}
      <input type="text" name={BREVO.honeypotField} tabindex="-1" autocomplete="off" aria-hidden="true" class="absolute left-[-9999px] h-0 w-0 opacity-0" />
      <input type="hidden" name={BREVO.localeField} value={lang} />
      <button
        type="submit"
        aria-label={copy.action}
        class="shrink-0 px-1 text-ink-soft transition-colors hover:text-terracotta"
      >→</button>
    </div>
  </form>
) : (
  <form action={action} method="POST">
    <div class="flex flex-col gap-3 sm:flex-row">
      <label for={emailId} class="sr-only">{copy.placeholder}</label>
      <input
        id={emailId}
        name={BREVO.emailField}
        type="email"
        required
        autocomplete="email"
        placeholder={copy.placeholder}
        class="w-full rounded-full border border-line-strong bg-paper px-5 py-3 text-ink placeholder:text-ink-faint transition-colors focus:border-ink/45 focus:outline-none"
      />
      <input type="text" name={BREVO.honeypotField} tabindex="-1" autocomplete="off" aria-hidden="true" class="absolute left-[-9999px] h-0 w-0 opacity-0" />
      <input type="hidden" name={BREVO.localeField} value={lang} />
      <button type="submit" class="pill shrink-0">
        {copy.action} <span class="arrow">→</span>
      </button>
    </div>
  </form>
)}
