---
/**
 * ScrollCue — indicateur de scroll signature.
 * Anneau de texte qui tourne lentement (textPath SVG) + flèche centrale.
 * Rotation figée si prefers-reduced-motion. Décoratif (aria-hidden).
 */
interface Props {
  lang: 'fr' | 'en';
}
const { lang } = Astro.props;
const phrase = lang === 'fr' ? 'SCROLLER · DÉCOUVRIR · ' : 'SCROLL · DISCOVER · ';
// deux répétitions, réparties uniformément sur tout le cercle via textLength
const ring = phrase.repeat(2);
const circumference = 226; // 2·π·r, r = 36
---

<div class="scrollcue" aria-hidden="true">
  <svg viewBox="0 0 100 100">
    <defs>
      <path id="scrollcue-path" d="M50,50 m-36,0 a36,36 0 1,1 72,0 a36,36 0 1,1 -72,0" />
    </defs>
    <g class="scrollcue__ring">
      <text textLength={circumference} lengthAdjust="spacing">
        <textPath href="#scrollcue-path" startOffset="0">{ring}</textPath>
      </text>
    </g>
    <path class="scrollcue__arrow" d="M50 45 V 55 M46 51 L50 55 L54 51" />
  </svg>
</div>

<style>
  .scrollcue {
    width: clamp(76px, 8vw, 102px);
    aspect-ratio: 1;
    color: var(--paper-on-dark);
    border-radius: 50%;
    /* léger fond pour garantir le contraste sur n'importe quelle zone de photo */
    background: radial-gradient(closest-side, rgba(20, 15, 12, 0.3), transparent 78%);
    filter: drop-shadow(0 1px 3px rgba(0, 0, 0, 0.3));
  }
  .scrollcue svg { width: 100%; height: 100%; }

  .scrollcue text {
    font-family: var(--font-ui);
    font-size: 8px;
    font-weight: 500;
    letter-spacing: 0.5px;
    fill: currentColor;
  }

  .scrollcue__ring {
    transform-box: fill-box;
    transform-origin: center;
    animation: scrollcue-spin 18s linear infinite;
  }

  .scrollcue__arrow {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.4;
    stroke-linecap: round;
    stroke-linejoin: round;
    opacity: 0.9;
  }

  @keyframes scrollcue-spin {
    to { transform: rotate(360deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .scrollcue__ring { animation: none; }
  }
</style>
