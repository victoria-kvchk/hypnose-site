---
/**
 * AxisIcon — icônes fines (trait) pour les pastilles des cartes axes.
 * cerveau · erlenmeyer (laboratoire) · feuille (pousse).
 */
interface Props {
  name: 'brain' | 'flask' | 'leaf';
  class?: string;
}
const { name, class: cls } = Astro.props;
---

{name === 'brain' && (
  <svg class={cls} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 6.2v11.6" />
    <path d="M12 7.2C11.1 5.8 8.9 5.7 7.9 7c-1.5-.3-2.8.9-2.5 2.4-1.2.7-1.3 2.4-.1 3.2-.4 1.4.8 2.7 2.2 2.5.5 1 1.9 1.4 2.9.8" />
    <path d="M12 7.2C12.9 5.8 15.1 5.7 16.1 7c1.5-.3 2.8.9 2.5 2.4 1.2.7 1.3 2.4.1 3.2.4 1.4-.8 2.7-2.2 2.5-.5 1-1.9 1.4-2.9.8" />
  </svg>
)}

{name === 'flask' && (
  <svg class={cls} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M9.5 3.5h5" />
    <path d="M10 3.5v4.8L5.8 17.4A1.6 1.6 0 0 0 7.2 19.8h9.6a1.6 1.6 0 0 0 1.4-2.4L14 8.3V3.5" />
    <path d="M7.7 14.5h8.6" />
  </svg>
)}

{name === 'leaf' && (
  <svg class={cls} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 20.5v-7.6" />
    <path d="M12 13.4c0-3.3 2.6-5.8 6.2-5.8.1 3.3-2.5 5.8-6.2 5.8z" />
    <path d="M12 15c0-2.6-2.1-4.6-5.1-4.6-.1 2.6 2 4.6 5.1 4.6z" />
  </svg>
)}
