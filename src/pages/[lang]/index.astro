---
import { Image } from 'astro:assets';
import LandingLayout from '../../layouts/LandingLayout.astro';
import Section from '../../components/Section.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ScrollCue from '../../components/ScrollCue.astro';
import Texture from '../../components/Texture.astro';
import AxisIcon from '../../components/AxisIcon.astro';
import heroImage from '../../assets/hero.jpg';
import axeMecanismes from '../../assets/axes/mecanismes.jpg';
import axeClinique from '../../assets/axes/clinique.jpg';
import axeApplications from '../../assets/axes/applications.jpg';
import { supportedLangs, type Lang } from '../../i18n/translations';
import { getLocalizedRoute } from '../../i18n/utils';

// visuels + icônes des axes, dans l'ordre des cartes
const axisImages = [axeMecanismes, axeClinique, axeApplications];
const axisIcons = ['brain', 'flask', 'leaf'] as const;

export function getStaticPaths() {
  return supportedLangs.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };

// Libellés du squelette (placeholders) — bilingues
const ui = {
  fr: {
    brand: 'Hypnose',
    nav: ['Recherche', 'Publications', 'Mission'],
    cta: 'Explorer la recherche',
    sections: {
      hero: { h: 'Comprendre l’hypnose autrement.', body: 'Un lieu dédié à la recherche scientifique sur l’hypnose et la thérapie par hypnose.' },
      quote: { text: 'L’hypnose n’est pas un état d’exception, mais une variation naturelle de la conscience.', lede: 'Les recherches contemporaines montrent des effets mesurables sur l’attention, la perception, la mémoire et le contrôle cognitif.', link: 'En savoir plus' },
      axes: { eyebrow: 'Axes de recherche', h: 'Explorer. Comprendre. Transmettre.' },
      pubs: { eyebrow: 'Publications récentes', h: 'Revue éditoriale minimaliste.', note: 'Liste : date · titre · revue · catégorie, séparée par des filets.' },
      mission: { eyebrow: 'Notre approche', h: 'Section mission, grande image sur la moitié de l’écran.', note: 'Manifeste — image 50% / texte 50%.' },
    },
    cards: [
      { title: 'Mécanismes cognitifs', body: 'Comment la suggestion module l’attention, la perception et le sentiment d’agentivité — observé par l’imagerie et la psychophysique.' },
      { title: 'Recherche clinique', body: 'Essais contrôlés, protocoles reproductibles et méta-analyses qui mesurent l’effet réel de l’hypnose en contexte de soin.' },
      { title: 'Applications thérapeutiques', body: 'De la douleur chronique à l’anxiété procédurale : où l’hypnose s’intègre, avec quelles indications et quelles limites.' },
    ],
    heroAlt: 'Paysage minéral abstrait vu du ciel',
    imageLabel: 'Image — texture aérienne abstraite',
    placeholderBody: 'Contenu à venir.',
    footerNote: 'Footer — sobre : wordmark, colonnes de liens, filet, mentions.',
    rights: 'Tous droits réservés.',
  },
  en: {
    brand: 'Hypnose',
    nav: ['Research', 'Publications', 'Mission'],
    cta: 'Explore the research',
    sections: {
      hero: { h: 'Understanding hypnosis, differently.', body: 'A place dedicated to scientific research on hypnosis and hypnotherapy.' },
      quote: { text: 'Hypnosis is not an exceptional state, but a natural variation of consciousness.', lede: 'Contemporary research shows measurable effects on attention, perception, memory and cognitive control.', link: 'Learn more' },
      axes: { eyebrow: 'Research axes', h: 'Explore. Understand. Share.' },
      pubs: { eyebrow: 'Recent publications', h: 'Minimalist editorial review.', note: 'List: date · title · journal · category, separated by hairlines.' },
      mission: { eyebrow: 'Our approach', h: 'Mission section, large image on half the screen.', note: 'Manifesto — 50% image / 50% text.' },
    },
    cards: [
      { title: 'Cognitive mechanisms', body: 'How suggestion modulates attention, perception and the sense of agency — observed through imaging and psychophysics.' },
      { title: 'Clinical research', body: 'Controlled trials, reproducible protocols and meta-analyses that measure the real effect of hypnosis in care settings.' },
      { title: 'Therapeutic applications', body: 'From chronic pain to procedural anxiety: where hypnosis fits, with which indications and limits.' },
    ],
    heroAlt: 'Abstract mineral landscape seen from above',
    imageLabel: 'Image — abstract aerial texture',
    placeholderBody: 'Content to come.',
    footerNote: 'Footer — sober: wordmark, link columns, hairline, legal.',
    rights: 'All rights reserved.',
  },
}[lang];
---

<LandingLayout>
  {/* Active l’état initial du reveal seulement si JS + mouvement autorisé (anti-FOUC) */}
  <script is:inline>
    if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.documentElement.classList.add('reveal-ready');
    }
  </script>

  {/* En-tête fixe : composant SiteHeader, monté par LandingLayout. */}

  {/* ═══════════ HERO — image plein cadre, titre sur le sable ═══════════ */}
  <section
    data-section="hero"
    class="relative isolate flex min-h-[clamp(580px,90vh,860px)] items-center overflow-hidden"
  >
    {/* image plein cadre + parallaxe/zoom (sable à gauche) */}
    <figure data-reveal class="reveal-fade absolute inset-0 overflow-hidden">
      <div class="media__parallax" data-parallax data-parallax-speed="0.08">
        <div class="media__zoom">
          <Image
            src={heroImage}
            alt={ui.heroAlt}
            loading="eager"
            fetchpriority="high"
            sizes="100vw"
            class="h-full w-full object-cover [object-position:28%_center]"
          />
        </div>
      </div>
    </figure>

    {/* voile sable dégradé pour la lisibilité du titre à gauche */}
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-r from-sand/92 via-sand/45 to-transparent"></div>
    {/* voile haut léger : lisibilité du header transparent sur toute la largeur */}
    <div class="pointer-events-none absolute inset-x-0 top-0 h-32 bg-gradient-to-b from-sand/65 to-transparent"></div>
    {/* overlay léger supplémentaire en mobile pour la lisibilité du texte */}
    <div class="pointer-events-none absolute inset-0 bg-sand/25 md:hidden"></div>

    {/* contenu */}
    <div class="wrap relative z-10">
      <div data-reveal class="max-w-xl py-24">
        <h1 class="t-h1 text-balance">{ui.sections.hero.h}</h1>
        <hr class="mt-8 h-px w-16 border-0 bg-terracotta" />
        <p class="mt-7 max-w-md text-pretty text-ink-soft">{ui.sections.hero.body}</p>
        <a href="#research" class="pill mt-9 w-full sm:w-auto">
          {ui.cta} <span class="arrow">→</span>
        </a>
      </div>
    </div>

    {/* indicateur de scroll signature, bas-droite de la photo */}
    <div class="absolute bottom-7 right-6 z-20 md:bottom-10 md:right-10">
      <ScrollCue lang={lang} />
    </div>
  </section>

  {/* ═══════════ 3 · CITATION — deux colonnes sur fond texturé ═══════════ */}
  <section data-section="quote" class="relative isolate overflow-hidden text-paper-on-dark">
    {/* fond texturé sombre */}
    <div class="absolute inset-0">
      <Texture variant="deep" seed={5} class="h-full w-full" />
    </div>
    {/* scrim pour le contraste du texte crème */}
    <div class="pointer-events-none absolute inset-0 bg-ink-deep/55"></div>

    {/* contenu deux colonnes */}
    <div class="wrap relative z-10 grid grid-cols-1 items-center gap-10 py-[clamp(96px,16vh,190px)] md:grid-cols-[1.55fr_1fr] md:gap-16">
      <blockquote data-reveal class="display t-quote text-balance text-paper-on-dark">
        «&nbsp;{ui.sections.quote.text}&nbsp;»
      </blockquote>
      <div data-reveal class="md:max-w-xs">
        <p class="text-pretty leading-relaxed text-paper-dim">{ui.sections.quote.lede}</p>
        <a href="#research" class="link-action link-action--cream mt-8">
          {ui.sections.quote.link} <span class="arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  {/* ═══════════ 4 · AXES (trois cartes) ═══════════ */}
  <Section id="research" section="axes">
    <SectionHeader
      reveal
      class="mb-16 max-w-2xl"
      eyebrow={ui.sections.axes.eyebrow}
      title={ui.sections.axes.h}
    />
    <div class="grid grid-cols-1 gap-x-10 gap-y-16 md:grid-cols-3">
        {ui.cards.map((card, i) => (
          <a href={getLocalizedRoute(lang, 'articles')} data-reveal class="group block">
            <div class="relative aspect-square w-full overflow-hidden rounded-[var(--radius)]">
              <Image
                src={axisImages[i]}
                alt={card.title}
                sizes="(min-width: 768px) 30vw, 100vw"
                class="h-full w-full object-cover transition-transform duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-[1.04]"
              />
              <div class="pointer-events-none absolute inset-0 rounded-[var(--radius)] ring-1 ring-inset ring-ink/5"></div>
              {/* pastille crème à cheval sur le bas de l'image */}
              <span class="absolute -bottom-6 left-5 z-10 flex h-[3.25rem] w-[3.25rem] items-center justify-center rounded-full bg-sand text-clay shadow-[0_5px_16px_-6px_rgba(31,31,31,0.4)] ring-1 ring-ink/5">
                <AxisIcon name={axisIcons[i]} class="h-6 w-6" />
              </span>
            </div>
            <h3 class="t-card mt-9 transition-colors group-hover:text-clay">{card.title}</h3>
            <p class="mt-3 text-ink-soft">{card.body}</p>
          </a>
        ))}
      </div>
  </Section>

  {/* ═══════════ 5 · PUBLICATIONS ═══════════ */}
  <Section id="publications" section="publications" class="bg-sand-2">
      <div class="flex flex-col justify-between gap-6 pb-10 md:flex-row md:items-end" data-reveal>
        <div>
          <p class="eyebrow mb-6">{ui.sections.pubs.eyebrow}</p>
          <h2 class="t-h2">{ui.sections.pubs.h}</h2>
        </div>
        <p class="max-w-xs text-[0.72rem] italic text-ink-faint md:text-right">{ui.sections.pubs.note}</p>
      </div>
      <hr class="hairline" />
      {[0, 1, 2, 3].map((row) => (
        <div data-reveal>
          <div class="grid grid-cols-1 items-baseline gap-2 py-7 md:grid-cols-[5rem_1fr_auto] md:gap-8">
            <span class="eyebrow !text-clay">20{25 - row}</span>
            <span class="t-card !text-[1.15rem] text-ink">{ui.placeholderBody}</span>
            <span class="eyebrow">Journal · Cat.</span>
          </div>
          <hr class="hairline" />
        </div>
      ))}
  </Section>

  {/* ═══════════ 6 · MISSION ═══════════ */}
  <section data-section="mission">
    <div class="grid grid-cols-1 md:grid-cols-2">
      <div class="placeholder h-[55vh] !rounded-none md:h-auto md:min-h-[88vh]" data-reveal>
        <span>{ui.imageLabel}</span>
      </div>
      <div class="flex items-center bg-sand px-[var(--gutter)] py-[var(--section-y)]">
        <div class="max-w-md" data-reveal>
          <SectionHeader eyebrow={ui.sections.mission.eyebrow} title={ui.sections.mission.h} />
          <p class="mt-6 text-ink-soft">{ui.placeholderBody}</p>
          <a href="#" class="link-action mt-9">{ui.cta} <span class="arrow">→</span></a>
          <p class="mt-8 text-[0.72rem] italic text-ink-faint">{ui.sections.mission.note}</p>
        </div>
      </div>
    </div>
  </section>

  {/* ═══════════ 7 · FOOTER ═══════════ */}
  <footer class="bg-sand">
    <div class="wrap pt-20 pb-10">
      <hr class="hairline mb-14" />
      <div class="grid grid-cols-2 gap-10 md:grid-cols-[1.5fr_repeat(3,1fr)]" data-reveal>
        <div class="col-span-2 md:col-span-1">
          <p class="display text-[1.5rem] text-ink">{ui.brand}<span class="text-terracotta">·</span></p>
          <p class="mt-4 max-w-xs text-[0.72rem] italic text-ink-faint">{ui.footerNote}</p>
        </div>
        {[0, 1, 2].map((col) => (
          <div>
            <p class="eyebrow mb-4">{ui.nav[col] ?? '—'}</p>
            <ul class="space-y-2.5">
              {[0, 1, 2].map(() => (
                <li><a href="#" class="text-[0.95rem] text-ink-soft hover:text-clay">{ui.placeholderBody}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      <div class="mt-16 flex flex-col gap-2 text-[0.72rem] text-ink-faint md:flex-row md:justify-between">
        <p>© 2026 {ui.brand}. {ui.rights}</p>
        <p class="eyebrow">Paris — 48.85°N</p>
      </div>
    </div>
  </footer>

  {/* Observateur d’apparition au scroll */}
  <script is:inline>
    (() => {
      if (!document.documentElement.classList.contains('reveal-ready')) return;
      const els = document.querySelectorAll('[data-reveal]');
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        }
      }, { rootMargin: '0px 0px -10% 0px', threshold: 0.1 });
      els.forEach((el, i) => {
        el.style.transitionDelay = Math.min(i % 4, 3) * 60 + 'ms';
        io.observe(el);
      });
    })();
  </script>

  {/* Parallaxe douce — vanilla, rAF, désactivée si réduction de mouvement */}
  <script is:inline>
    (() => {
      if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      const els = Array.from(document.querySelectorAll('[data-parallax]'));
      if (!els.length) return;

      let ticking = false;
      const update = () => {
        const vh = window.innerHeight;
        for (const el of els) {
          const r = el.getBoundingClientRect();
          // progression ~[-1, 1] : 0 quand l'élément est centré dans le viewport
          const center = r.top + r.height / 2;
          const prog = (center - vh / 2) / (vh / 2 + r.height / 2);
          const speed = parseFloat(el.getAttribute('data-parallax-speed') || '0.1');
          const shift = -prog * r.height * speed;
          el.style.transform = 'translate3d(0,' + shift.toFixed(1) + 'px,0)';
        }
        ticking = false;
      };
      const onScroll = () => {
        if (!ticking) { ticking = true; requestAnimationFrame(update); }
      };

      update();
      addEventListener('scroll', onScroll, { passive: true });
      addEventListener('resize', onScroll, { passive: true });
    })();
  </script>
</LandingLayout>
