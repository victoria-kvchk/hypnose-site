---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { type Lang } from '../../../i18n/translations';
import { getLocalizedRoute, t } from '../../../i18n/utils';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((entry) => ({
    params: { lang: entry.data.lang, slug: entry.id },
    props: { entry },
  }));
}

const { lang } = Astro.params as { lang: Lang };
const { entry } = Astro.props;
const a = entry.data;
const { Content } = await render(entry);

const dateOpts = { year: 'numeric', month: 'long', day: 'numeric' } as const;
const locale = lang === 'fr' ? 'fr-FR' : 'en-GB';
const dateStr = a.date.toLocaleDateString(locale, dateOpts);
const updatedStr = a.updated ? a.updated.toLocaleDateString(locale, dateOpts) : null;
const ui =
  lang === 'fr'
    ? { read: 'min de lecture', updated: 'mis à jour le', by: 'Par', keep: 'À retenir', brief: 'En bref', more: 'Pour aller plus loin', glossary: 'Glossaire', next: 'À lire ensuite', sources: 'Sources' }
    : { read: 'min read', updated: 'updated', by: 'By', keep: 'Key takeaway', brief: 'In brief', more: 'Going further', glossary: 'Glossary', next: 'Read next', sources: 'Sources' };
const metaBits = [a.category, a.kicker, dateStr, updatedStr ? `${ui.updated} ${updatedStr}` : null, a.readingMinutes ? `${a.readingMinutes} ${ui.read}` : null].filter(Boolean);

// SEO : données structurées Article
const canonical = `${Astro.site}${Astro.url.pathname.slice(1)}`;
const siteName = t(lang, 'site.title');
const author = 'Victoria';
const aboutUrl = `${Astro.site}${getLocalizedRoute(lang, 'about').slice(1)}`;
const publishedISO = a.date.toISOString();
const modifiedISO = (a.updated ?? a.date).toISOString();
const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: a.title,
  description: a.description,
  inLanguage: lang,
  datePublished: publishedISO,
  dateModified: modifiedISO,
  mainEntityOfPage: canonical,
  image: new URL('/og-default.jpg', Astro.site).href,
  author: { '@type': 'Person', name: author, url: aboutUrl },
  publisher: { '@type': 'Organization', name: siteName, url: Astro.site?.href },
};
---

<BaseLayout
  title={a.seoTitle ?? a.title}
  description={a.description}
  type="article"
  publishedTime={publishedISO}
  modifiedTime={modifiedISO}
  jsonLd={articleLd}
>
  <article class="section">
    <div class="wrap max-w-3xl">
      <p class="eyebrow !text-clay mb-6 flex flex-wrap items-center gap-x-2.5 gap-y-1">
        {metaBits.map((bit, i) => (
          <>
            {i > 0 && <span class="text-ink-faint/60">·</span>}
            <span class={i === 0 ? '' : 'text-ink-faint'}>{bit}</span>
          </>
        ))}
      </p>

      <h1 class="t-h1 mb-4 text-balance">{a.title}</h1>

      <p class="mb-10 text-[0.9rem] text-ink-soft">{ui.by} <a href={getLocalizedRoute(lang, 'about')} class="text-clay underline underline-offset-2 hover:text-terracotta">{author}</a></p>

      {a.summary && (
        <aside class="mb-12 rounded-[var(--radius)] border-l-2 border-clay bg-sand-2 px-6 py-5">
          <p class="eyebrow mb-2 !text-clay">{ui.keep}</p>
          <p class="leading-relaxed text-ink-soft">{a.summary}</p>
        </aside>
      )}

      <div class="article-prose">
        <Content />
      </div>

      {a.keyPoints && a.keyPoints.length > 0 && (
        <section class="mt-16 border-t border-line pt-8">
          <h2 class="eyebrow mb-4 text-ink-soft">{ui.brief}</h2>
          <ul class="space-y-3">
            {a.keyPoints.map((p) => (
              <li class="flex gap-3 text-ink-soft">
                <span class="shrink-0 text-clay">–</span>
                <span set:html={p.replace(/\[(\d+(?:\s*,\s*\d+)*)\]/g, (_m, g) =>
                  '<sup class="cite">' + String(g).split(',').map((n) => `<a class="cite-link" href="#src-${n.trim()}">${n.trim()}</a>`).join(', ') + '</sup>'
                )} />
              </li>
            ))}
          </ul>
        </section>
      )}

      {(a.glossary?.length || a.readNext?.length) && (
        <section class="mt-16 border-t border-line pt-8">
          <h2 class="eyebrow mb-4 text-ink-soft">{ui.more}</h2>
          {a.glossary && a.glossary.length > 0 && (
            <p class="text-ink-soft">
              <a href={getLocalizedRoute(lang, 'glossary')} class="text-clay underline underline-offset-2 hover:text-terracotta">{ui.glossary}</a>
              {' : '}{a.glossary.join(' · ')}
            </p>
          )}
          {a.readNext && a.readNext.length > 0 && (
            <p class="mt-3 text-ink-soft">{ui.next} : {a.readNext.map((r, i) => <span>{i > 0 ? ' · ' : ''}« {r} »</span>)}</p>
          )}
        </section>
      )}

      {a.sources && a.sources.length > 0 && (
        <section class="mt-16 border-t border-line pt-8">
          <h2 class="eyebrow mb-6 text-ink-soft">{ui.sources}</h2>
          <ol class="space-y-4 text-[0.85rem] leading-relaxed text-ink-soft">
            {a.sources.map((s, i) => (
              <li id={`src-${i + 1}`} class="flex scroll-mt-28 gap-3">
                <span class="shrink-0 text-ink-faint">{i + 1}.</span>
                <span>
                  {s.text}
                  {s.doi && (
                    <> <a href={`https://doi.org/${s.doi}`} target="_blank" rel="noopener noreferrer" class="whitespace-nowrap text-clay underline underline-offset-2 hover:text-terracotta">doi.org/{s.doi}</a></>
                  )}
                  {s.url && !s.doi && (
                    <> <a href={s.url} target="_blank" rel="noopener noreferrer" class="text-clay underline underline-offset-2 hover:text-terracotta">lien</a></>
                  )}
                </span>
              </li>
            ))}
          </ol>
        </section>
      )}

      {a.takeaway && (
        <p class="mt-16 border-t border-line pt-8 text-[0.95rem] italic leading-relaxed text-ink-faint">{a.takeaway}</p>
      )}
    </div>
  </article>
</BaseLayout>
