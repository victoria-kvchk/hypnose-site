---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { supportedLangs, type Lang } from '../../../i18n/translations';
import { t } from '../../../i18n/utils';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return supportedLangs.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };

const articles = (await getCollection('articles'))
  .filter((a) => a.data.lang === lang)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title={t(lang, 'articles.title')}>
  <section class="section">
    <div class="wrap max-w-3xl">
      <h1 class="t-h1 mb-12">
        {t(lang, 'articles.title')}
      </h1>

      {articles.length === 0 ? (
        <p class="text-ink-soft">{t(lang, 'articles.empty')}</p>
      ) : (
        <ul>
          {articles.map((article) => (
            <li>
              <a
                href={`/${lang}/articles/${article.id}/`}
                class="group block border-t border-line py-8"
              >
                <p class="eyebrow !text-clay mb-3">
                  {article.data.date.toLocaleDateString(lang === 'fr' ? 'fr-FR' : 'en-GB')}
                </p>
                <h2 class="t-card text-ink transition-colors group-hover:text-clay">
                  {article.data.title}
                </h2>
                <p class="mt-2 text-ink-soft">{article.data.description}</p>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</BaseLayout>
