---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { supportedLangs, type Lang } from '../../../i18n/translations';
import { t } from '../../../i18n/utils';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return supportedLangs.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };

const articles = (await getCollection('articles'))
  .filter((a) => a.data.lang === lang)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title={t(lang, 'articles.title')}>
  <div class="mx-auto max-w-5xl px-4 py-16">
    <h1 class="text-4xl font-bold text-primary-800 mb-8">
      {t(lang, 'articles.title')}
    </h1>

    {articles.length === 0 ? (
      <p class="text-gray-600">{t(lang, 'articles.empty')}</p>
    ) : (
      <ul class="space-y-8">
        {articles.map((article) => (
          <li>
            <a
              href={`/${lang}/articles/${article.id}/`}
              class="block group"
            >
              <h2 class="text-xl font-semibold text-primary-700 group-hover:text-primary-900 transition-colors">
                {article.data.title}
              </h2>
              <p class="text-sm text-gray-500 mt-1">
                {article.data.date.toLocaleDateString(lang === 'fr' ? 'fr-FR' : 'en-GB')}
              </p>
              <p class="text-gray-600 mt-2">{article.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</BaseLayout>
