---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { supportedLangs, type Lang } from '../../i18n/translations';
import { t } from '../../i18n/utils';
import { routes } from '../../i18n/routes';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  const pageKeys = ['bibliography', 'about', 'contact'];
  const paths: { params: { lang: string; slug: string }; props: { routeKey: string } }[] = [];

  for (const lang of supportedLangs) {
    for (const routeKey of pageKeys) {
      const localizedPath = routes[routeKey]?.[lang as Lang];
      if (!localizedPath) continue;
      const slug = localizedPath.replace(/^\/|\/$/g, '');
      paths.push({
        params: { lang, slug },
        props: { routeKey },
      });
    }
  }

  return paths;
}

const { lang } = Astro.params as { lang: Lang };
const { routeKey } = Astro.props;

const title = t(lang, `${routeKey}.title` as any);

let bibliographyRefs: any[] = [];
if (routeKey === 'bibliography') {
  const entries = await getCollection('bibliography');
  bibliographyRefs = entries
    .filter((e) => e.id.startsWith(`${lang}/`))
    .flatMap((e) => e.data.references ?? []);
}
---

<BaseLayout title={title}>
  <section class="section">
    <div class="wrap max-w-3xl">
      <h1 class="t-h1 mb-12">{title}</h1>

      {routeKey === 'bibliography' && (
        bibliographyRefs.length === 0 ? (
          <p class="text-ink-soft">{t(lang, 'bibliography.empty')}</p>
        ) : (
          <ul>
            {bibliographyRefs.map((ref) => (
              <li class="border-t border-line py-6">
                <p class="t-card text-ink">{ref.title}</p>
                <p class="mt-1 text-[0.92rem] text-ink-soft">
                  {ref.authors.join(', ')} ({ref.year})
                </p>
                {ref.journal && <p class="text-[0.92rem] italic text-ink-faint">{ref.journal}</p>}
                {ref.doi && (
                  <a
                    href={`https://doi.org/${ref.doi}`}
                    class="link-action mt-3"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    DOI&nbsp;: {ref.doi} <span class="arrow">→</span>
                  </a>
                )}
              </li>
            ))}
          </ul>
        )
      )}

      {routeKey === 'about' && (
        <p class="max-w-prose text-[1.06rem] leading-relaxed text-ink-soft">
          {t(lang, 'about.content')}
        </p>
      )}

      {routeKey === 'contact' && (
        <div class="max-w-prose text-[1.06rem] leading-relaxed text-ink-soft">
          <p>{t(lang, 'contact.content')}</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
