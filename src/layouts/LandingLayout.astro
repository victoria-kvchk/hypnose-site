---
import '../styles/global.css';
import SEOHead from '../components/SEOHead.astro';
import Fonts from '../components/Fonts.astro';
import { getLangFromUrl, t } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
}

const lang = getLangFromUrl(Astro.url);
const { title, description } = Astro.props;

const pageTitle = title
  ? `${title} | ${t(lang, 'site.title')}`
  : t(lang, 'site.title');
const pageDescription = description ?? t(lang, 'site.description');
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang={lang}>
  <head>
    <SEOHead
      title={pageTitle}
      description={pageDescription}
      lang={lang}
      currentPath={currentPath}
    />
    <Fonts />
  </head>
  <body class="min-h-screen bg-sand-100 text-ink antialiased">
    <slot />
  </body>
</html>
